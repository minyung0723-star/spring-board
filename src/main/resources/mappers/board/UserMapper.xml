<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.board.springboard.model.mapper.UserMapper">
    <select id="전체유저들" resultType="com.board.springboard.model.dto.User">
        SELECT *
        FROM users
    </select>
    <insert id="회원가입" parameterType="com.board.springboard.model.dto.User">
        INSERT INTO users(name, email, create_at)
        VALUES           (#{name}, #{email}, NOW())
    </insert>
    <select id="이메일중복체크" parameterType="String" resultType="int">
        SELECT COUNT(*)
        FROM users
        WHERE email = #{email}
    </select>

    <select id="로그인" parameterType="String" resultType="com.board.springboard.model.dto.User">
        SELECT *
        FROM users
        WHERE email = #{email}
    </select>

    <select id="이메일로유저찾기" parameterType="String" resultType="com.board.springboard.model.dto.User">
        <!-- TODO 3. users 테이블에서 email 이 일치하는 유저 전체를 조회하시오 -->
        SELECT *
        FROM users
        WHERE email = #{email}
    </select>

    <update id="프로필사진수정" parameterType="com.board.springboard.model.dto.User">
        UPDATE users
        SET profile_img = #{profile_img}
        WHERE id = ${id}
        <!-- WHERE 을 작성하지 않으면 users 테이블에 존재하는 모~든 프로필이미지 수정 -->
    </update>

    <!-- TODO 1: 태그명, id, parameterType, resultType 을 채우세요 -->
    <select id="유저단건조회" parameterType="int" resultType="com.board.springboard.model.dto.User">
        SELECT *
        FROM users
        WHERE id = #{id}
    </select>

    <update id="유저정보수정" parameterType="com.board.springboard.model.dto.User">
        UPDATE users
        SET name  = #{name},
            email = #{email}
        WHERE id = #{id}
    </update>
</mapper>